@model EventEaseBookingApp.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h1 class="card-title mb-3">Venue Details</h1>
                <hr />

                <dl class="row">
                    <dt class="col-sm-4">Venue Name</dt>
                    <dd class="col-sm-8">@Model.VenueName</dd>

                    <dt class="col-sm-4">Location</dt>
                    <dd class="col-sm-8">@Model.Location</dd>

                    <dt class="col-sm-4">Capacity</dt>
                    <dd class="col-sm-8">@Model.Capacity</dd>

                    <dt class="col-sm-4">Image</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" width="150" height="100" style="object-fit:cover; border-radius:8px;" />
                        }
                        else
                        {
                            <span>No Image</span>
                        }
                    </dd>
                </dl>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-primary btn-lg">Edit</a>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Back</a>
                </div>
            </div>
        </div>
    </div>
</div>