@model EventEaseBookingApp.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

        <div class="card shadow-sm mt-4">
            <div class="card-body">

                <h1 class="card-title mb-3 text-danger">Delete Venue</h1>
                <hr />

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                @if (Model == null)
                {
                    <div class="alert alert-warning">
                        Venue not found or already deleted.
                    </div>

                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                }
                else
                {
                    <h5 class="mb-3">Are you sure you want to delete this venue?</h5>

                    <dl class="row">
                        <dt class="col-sm-4">Venue Name</dt>
                        <dd class="col-sm-8">@Model.VenueName</dd>

                        <dt class="col-sm-4">Location</dt>
                        <dd class="col-sm-8">@Model.Location</dd>

                        <dt class="col-sm-4">Capacity</dt>
                        <dd class="col-sm-8">@Model.Capacity</dd>

                        <dt class="col-sm-4">Image</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" width="150" height="100"
                                     style="object-fit:cover; border-radius:8px;" />
                            }
                            else
                            {
                                <span>No Image</span>
                            }
                        </dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="VenueId" />

                        <div class="d-flex justify-content-between mt-4">
                            <input type="submit" value="Delete" class="btn btn-danger btn-lg" />
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        </div>
                    </form>
                }

            </div>
        </div>

    </div>
</div>