@model EventEaseBookingApp.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h1 class="card-title mb-3 text-danger">Delete Booking</h1>
                <hr />

                <h5 class="mb-3">Are you sure you want to delete this booking?</h5>

                <dl class="row">
                    <dt class="col-sm-4">Booking Date</dt>
                    <dd class="col-sm-8">@Model.BookingDate.ToString("yyyy-MM-dd HH:mm")</dd>

                    <dt class="col-sm-4">Venue</dt>
                    <dd class="col-sm-8">@Model.Venue?.VenueName ?? "N/A"</dd>

                    <dt class="col-sm-4">Event</dt>
                    <dd class="col-sm-8">@Model.Event?.EventName ?? "N/A"</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="BookingId" />
                    <div class="d-flex justify-content-between mt-4">
                        <input type="submit" value="Delete" class="btn btn-danger btn-lg" />
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>