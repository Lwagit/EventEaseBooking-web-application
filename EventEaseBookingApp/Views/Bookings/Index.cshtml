@model IEnumerable<EventEaseBookingApp.Models.BookingViewModel>

@{
    ViewData["Title"] = "Bookings";
}

<h1 class="mb-4">Bookings</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
</p>

@if (!Model.Any())
{
    <p>No bookings found.</p>
}
else
{
    <table class="table table-striped table-hover shadow-sm rounded">
        <thead class="table-primary">
            <tr>
                <th>Booking Date</th>
                <th>Venue</th>
                <th>Event</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@booking.VenueName</td>
                    <td>@booking.EventName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                        <a asp-action="Details" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-info me-1">Details</a>
                        <a asp-action="Delete" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}