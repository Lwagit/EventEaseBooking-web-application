@model EventEaseBookingApp.Models.Booking

@{
    ViewData["Title"] = "Edit Booking";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h1 class="card-title mb-3">Edit Booking</h1>
                <hr />

                <form asp-action="Edit">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="BookingId" />

                    <div class="form-group mb-3">
                        <label asp-for="BookingDate"></label>
                        <input asp-for="BookingDate" class="form-control" type="datetime-local" />
                        <span asp-validation-for="BookingDate" class="text-danger"></span>
                    </div>

                    <!-- FIXED DROPDOWN -->
                    <div class="form-group mb-3">
                        <label asp-for="VenueId"></label>
                        <select asp-for="VenueId"
                                class="form-control"
                                asp-items="ViewBag.Venues">
                        </select>
                        <span asp-validation-for="VenueId" class="text-danger"></span>
                    </div>

                    <!-- FIXED DROPDOWN -->
                    <div class="form-group mb-3">
                        <label asp-for="EventId"></label>
                        <select asp-for="EventId"
                                class="form-control"
                                asp-items="ViewBag.Events">
                        </select>
                        <span asp-validation-for="EventId" class="text-danger"></span>
                    </div>

                    <div class="form-group mt-4 d-flex justify-content-between">
                        <input type="submit" value="Save" class="btn btn-primary btn-lg" />
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}