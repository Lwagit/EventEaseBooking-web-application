@model EventEaseBookingApp.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h1 class="card-title mb-3">Event Details</h1>
                <hr />

                <dl class="row">
                    <dt class="col-sm-4">Event Name</dt>
                    <dd class="col-sm-8">@Model.EventName</dd>

                    <dt class="col-sm-4">Event Date</dt>
                    <dd class="col-sm-8">@Model.EventDate.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@Model.Description</dd>
                </dl>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-primary btn-lg">Edit</a>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Back</a>
                </div>
            </div>
        </div>
    </div>
</div>