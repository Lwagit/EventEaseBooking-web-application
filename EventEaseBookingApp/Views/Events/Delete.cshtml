@model EventEaseBookingApp.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

        <div class="card shadow-sm mt-4">
            <div class="card-body">

                <h1 class="card-title mb-3 text-danger">Delete Event</h1>
                <hr />

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                @if (Model == null)
                {
                    <div class="alert alert-warning">
                        Event not found or already deleted.
                    </div>

                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                }
                else
                {
                    <h5 class="mb-3">Are you sure you want to delete this event?</h5>

                    <dl class="row">
                        <dt class="col-sm-4">Event Name</dt>
                        <dd class="col-sm-8">@Model.EventName</dd>

                        <dt class="col-sm-4">Event Date</dt>
                        <dd class="col-sm-8">@Model.EventDate.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="EventId" />

                        <div class="d-flex justify-content-between mt-4">
                            <input type="submit" value="Delete" class="btn btn-danger btn-lg" />
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        </div>
                    </form>
                }

            </div>
        </div>

    </div>
</div>