@model IEnumerable<EventEaseBookingApp.Models.BookingViewModel>

@{
    ViewData["Title"] = "Booking Search";
}

<h1 class="mb-3">Booking Search (Specialist View)</h1>

<!-- SEARCH BAR -->
<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="search"
               value="@Context.Request.Query["search"]"
               class="form-control"
               placeholder="Search by Booking ID, Event or Venue..." />

        <button class="btn btn-primary" type="submit">
            Search
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Reset
        </a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No bookings found.
    </div>
}
else
{
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-primary">
            <tr>
                <th>Booking ID</th>
                <th>Booking Date</th>
                <th>Venue</th>
                <th>Event</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.BookingId</td>
                    <td>@b.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@b.VenueName</td>
                    <td>@b.EventName</td>
                </tr>
            }
        </tbody>
    </table>
}